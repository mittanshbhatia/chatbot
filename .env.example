# Copy to .env.local for local `vercel dev` (never commit real keys).
# Use a SEPARATE Supabase project for this chatbot (do not reuse other apps).

# Client (safe to expose with RLS)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server only (Vercel env) — never ship to the client
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
